{
  "version": 2,
  "buildCommand": "npm install -g pnpm && pnpm install && pnpm --filter @workspace/barber-mt run build",
  "outputDirectory": "artifacts/barber-mt/dist/public",
  "installCommand": "npm install -g pnpm && pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
